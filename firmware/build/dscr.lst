      000056 05                     166 	.db	DSCR_ENDPOINT_TYPE
      000057 86                     167 	.db	0x86				;  ep6 dir=in and address
      000058 02                     168 	.db	ENDPOINT_TYPE_BULK	; type
      000059 40                     169 	.db	0x40				; max packet LSB
      00005A 00                     170 	.db	0x00				; max packet size=64 bytes
      00005B 00                     171 	.db	0x00				; polling interval
                                    172 
      00005C                        173 fullspd_dscr_realend:
                                    174 
      00005C                        175 .even
      00005C                        176 _dev_strings:
                                    177 ; sample string
      00005C                        178 _string0:
      00005C 04                     179 	.db	string0end-_string0 ; len
      00005D 03                     180 	.db	DSCR_STRING_TYPE
      00005E 09 04                  181     .db 0x09, 0x04     ; who knows
      000060                        182 string0end:
                                    183 ; add more strings here
                                    184 
      000060                        185 _string1:
      000060 06                     186     .db string1end-_string1
      000061 03                     187     .db DSCR_STRING_TYPE
      000062 48                     188     .ascii 'H'
      000063 00                     189     .db 0
      000064 69                     190     .ascii 'i'
      000065 00                     191     .db 0
      000066                        192 string1end:
                                    193 
      000066                        194 _string2:
      000066 0C                     195     .db string2end-_string2
      000067 03                     196     .db DSCR_STRING_TYPE
      000068 54                     197     .ascii 'T'
      000069 00                     198     .db 0
      00006A 68                     199     .ascii 'h'
      00006B 00                     200     .db 0
      00006C 65                     201     .ascii 'e'
      00006D 00                     202     .db 0
      00006E 72                     203     .ascii 'r'
      00006F 00                     204     .db 0
      000070 65                     205     .ascii 'e'
      000071 00                     206     .db 0
      000072                        207 string2end:
                                    208 
      000072                        209 _string3:
      000072 0C                     210     .db string3end-_string3
      000073 03                     211     .db DSCR_STRING_TYPE
      000074 69                     212     .ascii 'i'
      000075 00                     213     .db 0
      000076 46                     214     .ascii 'F'
      000077 00                     215     .db 0
      000078 61                     216     .ascii 'a'
      000079 00                     217     .db 0
      00007A 63                     218     .ascii 'c'
      00007B 00                     219     .db 0
      00007C 65                     220     .ascii 'e'
